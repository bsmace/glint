    "playwright": "^1.61.1",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "^7.0.2",
    "wxt": "^0.20.27"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@floating-ui/dom": "^1.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.4",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.16.0",
    "react": "^19",
    "react-dom": "^19",
