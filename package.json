{
  "name": "glint",
  "private": true,
  "version": "1.0.0",
  "description": "Browser extension - overlay prompt assistant",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
